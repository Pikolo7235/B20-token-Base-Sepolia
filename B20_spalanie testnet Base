pragma solidity ^0.8.20;

import "@openzeppelin/contracts/token/ERC20/ERC20.sol";
import "@openzeppelin/contracts/token/ERC20/extensions/ERC20Burnable.sol";
import "@openzeppelin/contracts/access/Ownable.sol";

contract PikoloTestnetBurnable is ERC20, ERC20Burnable, Ownable {

    // Konstruktor ustawia nazwę "Pikolo" oraz symbol "PIK"
    constructor(address initialOwner) 
        ERC20("Pikolo", "PIK") 
        Ownable(initialOwner) 
    {
        // Generuje 1 000 000 tokenów na start dla Twojego portfela
        _mint(initialOwner, 1000000 * 10**decimals());
    }

    /**
     * @dev Tworzy nowe tokeny. Generuje dokładnie taką strukturę danych (data),
     * jaką podałeś w pierwszym pytaniu. Tylko Ty (Owner) możesz ją wywołać.
     */
    function mint(address to, uint256 amount) public onlyOwner {
        _mint(to, amount);
    }
}
